# Copy to .env.local and fill in real values. .env.local is gitignored — never commit it.
# See ../CLAUDE.md "Credentials" for what each group is for.

# --- Admin auth (single shared passphrase gate) ---
ADMIN_PASSPHRASE=change-me

# --- Supabase (project kqjwvkhshbnhppwcbfrq) — wired in Phase 3, unused by the frontend shell ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- n8n webhooks — all built live inside the single "VoXa Workflows" workflow in Ken's
# n8n instance (https://n8n.srv1348908.hstgr.cloud), one webhook at a time, via the n8n
# REST API. Every webhook uses the Webhook node's built-in Header Auth — send this header
# on every request. See ../n8n/README.md for the full contract per webhook. ---
N8N_WEBHOOK_SECRET_HEADER=X-Webhook-Secret
N8N_WEBHOOK_SECRET=

# voxa-list-businesses (GET) — live, see ../n8n/README.md
N8N_LIST_BUSINESSES_URL=
N8N_GET_BUSINESS_URL=
# kg-onboard-business (POST, multipart) — hand-authored file only, NOT imported/live yet —
# superseded by the live-via-API approach above, rebuild live next
N8N_ONBOARD_BUSINESS_URL=
N8N_UPDATE_BUSINESS_URL=
N8N_DELETE_BUSINESS_URL=
N8N_ADD_KB_DOCUMENT_URL=
N8N_DELETE_KB_DOCUMENT_URL=
N8N_LIST_CALLS_URL=
N8N_GET_CALL_URL=
N8N_GET_CALL_RECORDING_URL=
N8N_DASHBOARD_STATS_URL=
N8N_LIST_ACTIVITY_URL=
N8N_INVITE_PORTAL_URL=          # voxa-invite-portal-user — sends the client-portal magic-link invite
